# ─────────────────────────────────────────────────────────────
# 환경변수 예시 파일
# 실제 값을 채운 뒤 `.env.local`로 복사하세요. (`.env.local`은 .gitignore 처리됨)
#   cp .env.example .env.local
# 값은 절대 깃에 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# ── 노션 (필수) ──────────────────────────────────────────────
# 노션 인테그레이션 토큰 (https://www.notion.so/my-integrations 에서 발급, ntn_... 형식)
NOTION_TOKEN=

# 결과 카드 CTA가 향하는 공개 노션 대시보드 URL (예: https://<workspace>.notion.site/<id>?v=<view>)
NOTION_DASHBOARD_URL=

# 노션 데이터소스 ID (2026-03-11 API 기준 data_source_id).
# 각 DB의 URL/스키마 조회로 확인 가능.
NOTION_DS_RUNNING=          # 러닝 기록 DB
NOTION_DS_CHALLENGERS=      # 챌린저 명단 DB
NOTION_DS_APPLICANTS=       # 신청자 DB
NOTION_DS_CHALLENGE_INFO=   # 챌린지 정보(발송 상태 토글 등) DB
NOTION_DS_MESSAGE_LOG=      # 메시지 발송 로그 DB
NOTION_DS_MESSAGE_TEMPLATE= # 메시지 템플릿 DB

# ── Gemini Vision OCR (필수) ─────────────────────────────────
# Google AI Studio에서 발급 (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ── Solapi SMS/LMS (문자 발송 사용 시) ───────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=              # 사전 등록된 발신번호 (숫자만, 예: 0212345678)

# ── 보안 시크릿 (webhook/cron 보호) ──────────────────────────
# 64자 hex 등 충분히 긴 난수 권장: `openssl rand -hex 32`
WEBHOOK_SECRET=
CRON_SECRET=

# ── 선택 ─────────────────────────────────────────────────────
CRON_TEST_NICKNAME=        # 크론 테스트 시 단일 대상 닉네임 (비우면 전체 대상)

# ── 일회성 셋업 스크립트 전용 (scripts/, sync-emoji-icons.mjs) ──
# 대부분의 사용자는 비워둬도 됩니다. DB를 코드로 생성/수정할 때만 사용.
NOTION_PARENT_PAGE_ID=     # 새 DB를 만들 상위 페이지 ID
NOTION_TEMPLATE_DB_ID=     # 메시지 템플릿 DB ID
NOTION_TEMPLATE_DS_ID=     # 메시지 템플릿 데이터소스 ID
NOTION_EMOJI_SOURCE_DB_ID= # 이모지 동기화 원본 DB ID
NOTION_EMOJI_TARGET_DB_ID= # 이모지 동기화 대상 DB ID
